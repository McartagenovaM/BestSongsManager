@model List<SongManager.Models.Song>
@{
    ViewData["Title"] = "Favorite Songs";
}

<div class="row mb-4">
    <div class="col-12">
        <h1>Favorite Songs</h1>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No favorite songs yet. <a href="/Songs">Add some favorites</a>
    </div>
}
else
{
    <div class="row">
        @foreach (var song in Model)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100 border-danger">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title">@song.Title</h5>
                            <span class="badge bg-danger">★</span>
                        </div>
                        <p class="card-text text-muted">@song.Artist</p>
                        <p class="card-text small">@song.Album (@song.Year)</p>
                        <p class="card-text small"><strong>Genre:</strong> @song.Genre</p>
                    </div>
                    <div class="card-footer bg-white">
                        <a href="/Songs/Details/@song.Id" class="btn btn-sm btn-info">View</a>
                        <a href="/Songs/Edit/@song.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form method="post" action="/Songs/Delete/@song.Id" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a href="/Songs" class="btn btn-secondary mt-3">Back to All Songs</a>
